# =============================================================================
# EarnGrid — Web App Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# All NEXT_PUBLIC_ vars are exposed to the browser at build time.
# =============================================================================

# ── Chain ─────────────────────────────────────────────────────────────────────
# Base Mainnet = 8453, Base Sepolia = 84532
NEXT_PUBLIC_CHAIN_ID=8453

# RPC endpoint for reading chain state (e.g., https://mainnet.base.org)
NEXT_PUBLIC_RPC_URL=

# ── Indexer ───────────────────────────────────────────────────────────────────
# URL of the EarnGrid indexer service (e.g., http://localhost:3001)
NEXT_PUBLIC_INDEXER_URL=http://localhost:3001

# ── Vault ─────────────────────────────────────────────────────────────────────
# Deployed vault contract address
NEXT_PUBLIC_VAULT_ADDRESS=

# USDC token contract address
NEXT_PUBLIC_USDC_ADDRESS=

# USDC decimal places (6 on Base mainnet and Base Sepolia)
NEXT_PUBLIC_USDC_DECIMALS=6
