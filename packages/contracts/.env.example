# =============================================================================
# EarnGrid — Contracts Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Used by Foundry scripts (forge) for deployment and configuration.
# =============================================================================

# ── Deployment ────────────────────────────────────────────────────────────────
DEPLOYER_KEY=                          # Private key of the deployer address

# ── Vault Roles ───────────────────────────────────────────────────────────────
VAULT_OWNER=                           # Owner address: role management, feeRecipient, timelock config
VAULT_CURATOR=                         # Curator address: schedule/execute strategy additions, cap/tier changes
VAULT_ALLOCATOR=                       # Allocator address: rebalance, harvest, update queues
VAULT_GUARDIAN=                        # Guardian address: pause deposits/withdrawals, emergency remove strategies
FEE_RECIPIENT=                         # Address that receives protocol fees

# ── Network ───────────────────────────────────────────────────────────────────
# Base Sepolia USDC token address (Sepolia only — leave blank for mainnet)
BASE_SEPOLIA_USDC=

RPC_URL=                               # RPC endpoint URL (e.g., https://mainnet.base.org)

# ── Vault Tuning (optional — defaults apply if omitted) ──────────────────────
TIER0_MAX_BPS=                         # Max allocation for Tier 0 strategies (basis points, e.g., 10000 = 100%)
TIER1_MAX_BPS=                         # Max allocation for Tier 1 strategies (basis points)
TIER2_MAX_BPS=                         # Max allocation for Tier 2 strategies (basis points)
IDLE_LIQUIDITY_BPS=                    # Target idle liquidity of total assets (basis points)
MIN_INITIAL_DEPOSIT=                   # Minimum initial deposit amount (in USDC units)
MAX_DAILY_INCREASE_BPS=                # Max daily increase in a strategy's allocation (basis points)
MIN_HARVEST_INTERVAL=                  # Minimum time between harvests (seconds)
TIMELOCK_DELAY=                        # Timelock delay for scheduled operations (seconds)
