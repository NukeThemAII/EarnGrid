# Required: RPC endpoint for Base chain
RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Required: Private key with ALLOCATOR_ROLE on the vault
PRIVATE_KEY=0x...

# Required: Address of the BlendedVault contract
VAULT_ADDRESS=0x...

# Morpho Blue GraphQL API endpoint (default: https://blue-api.morpho.org/graphql)
MORPHO_API_URL=https://blue-api.morpho.org/graphql

# Poll interval in milliseconds (default: 12 hours = 43200000)
POLL_INTERVAL_MS=43200000

# Harvest interval in milliseconds (default: 6 hours = 21600000)
HARVEST_INTERVAL_MS=21600000

# Minimum APY improvement in basis points to trigger rebalance (default: 50 = 0.5%)
MIN_APY_IMPROVEMENT_BPS=50

# Gas limit bump multiplier (default: 1.2 = 20% bump)
GAS_LIMIT_BUMP=1.2

# Dry-run mode: set to "true" to log actions without sending transactions
DRY_RUN=false

# Chain ID for Base (default: 8453)
CHAIN_ID=8453
