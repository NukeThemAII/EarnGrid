# =============================================================================
# EarnGrid — Indexer Service Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# =============================================================================

# ── Blockchain ────────────────────────────────────────────────────────────────
# RPC endpoint for the chain the vault is deployed on
INDEXER_RPC_URL=

# Deployed vault contract address to monitor
VAULT_ADDRESS=

# ── Database ──────────────────────────────────────────────────────────────────
# Connection string. SQLite default below; for production use PostgreSQL:
#   postgres://user:pass@host:5432/earngrid_indexer
DATABASE_URL=sqlite:./indexer.db

# ── Indexing ──────────────────────────────────────────────────────────────────
# Block number to start indexing from (0 = genesis, or specify deployment block)
START_BLOCK=0

# How often to poll for new blocks (milliseconds)
POLL_INTERVAL_MS=12000

# How often to sample and persist vault state snapshots (seconds)
SAMPLE_INTERVAL_SEC=3600

# Number of confirmations before considering a block final
FINALITY_BLOCKS=64

# Maximum number of blocks to fetch in a single RPC batch request
MAX_BLOCK_RANGE=2000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Rate-limit window duration (seconds)
RATE_LIMIT_WINDOW_SEC=60

# Maximum requests allowed per window
RATE_LIMIT_MAX=100

# ── Server ────────────────────────────────────────────────────────────────────
# HTTP server port for the indexer API
PORT=3001
